# ============================================
# CommerceHub MCP - Variables de Entorno
# ============================================
# Copia este archivo como .env y completa tus credenciales

# --- Shopify ---
SHOPIFY_STORE_URL=https://tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Para OAuth2 (apps públicas):
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# --- WooCommerce ---
WOOCOMMERCE_URL=https://tu-tienda.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe ---
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
# Formato: sk_live_xxx o sk_test_xxx

# --- MercadoLibre ---
MERCADOLIBRE_APP_ID=123456789
MERCADOLIBRE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOLIBRE_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOLIBRE_REFRESH_TOKEN=TG-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Sitio: MLA (Argentina), MLM (México), MLB (Brasil), MLC (Chile), etc.
MERCADOLIBRE_SITE_ID=MLM

# --- General ---
# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
# TTL del cache en segundos (default: 300 = 5 min)
CACHE_TTL=300
# Máximo de items en cache (default: 1000)
CACHE_MAX_SIZE=1000
